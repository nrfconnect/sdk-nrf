menu "Nordic Fast Pair Locator tag sample"

choice APP_PLATFORM
	prompt "Application platform"
	default APP_PLATFORM_DK
	default APP_PLATFORM_THINGY if BOARD_THINGY53
	default APP_PLATFORM_TAG if BOARD_NRF54L15TAG

config APP_PLATFORM_DK
	bool "Application runs on the Development Kit"
	depends on !BOARD_THINGY53 && !BOARD_NRF54L15TAG

config APP_PLATFORM_THINGY
	bool "Application runs on the Thingy:53"
	depends on BOARD_THINGY53

config APP_PLATFORM_TAG
	bool "Application runs on the nRF54L15 TAG"
	depends on BOARD_NRF54L15TAG

endchoice

rsource "Kconfig.battery"
rsource "Kconfig.dfu"
rsource "Kconfig.ranging"
rsource "Kconfig.ui"

config SETTINGS
	default y

config ZMS
	default y if (SOC_FLASH_NRF_RRAM || SOC_FLASH_NRF_MRAM)

config NVS
	default y if !(SOC_FLASH_NRF_RRAM || SOC_FLASH_NRF_MRAM)

endmenu

source "Kconfig.zephyr"
