menu "Nordic Fast Pair Locator tag sample"

config APP_PLATFORM_DK
	bool
	default y
	depends on !APP_PLATFORM_REF

config APP_PLATFORM_REF
	bool
	default y
	depends on BOARD_THINGY53 || BOARD_NRF54L15TAG

rsource "Kconfig.battery"
rsource "Kconfig.dfu"
rsource "Kconfig.motion_detector"
rsource "Kconfig.ranging"
rsource "Kconfig.ui"

config SETTINGS
	default y

config ZMS
	default y if (SOC_FLASH_NRF_RRAM || SOC_FLASH_NRF_MRAM)

config NVS
	default y if !(SOC_FLASH_NRF_RRAM || SOC_FLASH_NRF_MRAM)

endmenu

source "Kconfig.zephyr"
