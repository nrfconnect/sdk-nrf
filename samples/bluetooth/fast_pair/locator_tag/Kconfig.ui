config APP_UI_USE_HW_SPEAKER
	bool
	default y
	depends on $(dt_alias_enabled,pwm-spk)

config APP_UI_SPEAKER_FREQ
	int "Speaker frequency [Hz]"
	default 4000
	depends on APP_UI_USE_HW_SPEAKER
	help
	  Frequency of every sound generated by the speaker.
