source "Kconfig.zephyr"

menu "Nordic HIDS BLE GATT mouse service sample"

config BT_HIDS_SECURITY_ENABLED
	bool "Enable Bluetooth LE security"
	default y
	imply BT_PRIVACY
	select BT_SMP
	select BT_SETTINGS
	select FLASH
	select FLASH_PAGE_LAYOUT
	select FLASH_MAP
	select SETTINGS
	imply ZMS if (SOC_FLASH_NRF_RRAM || SOC_FLASH_NRF_MRAM)
	imply NVS if !(SOC_FLASH_NRF_RRAM || SOC_FLASH_NRF_MRAM)
	help
	  Enable Bluetooth LE security support.

config BT_HIDS_SECURITY_MITM_ENABLED
	bool "Enable passkey display MITM protection"
	depends on BT_HIDS_SECURITY_ENABLED
	depends on PRINTK
	default y
	help
	  Enable displaying passkey for Man-In-The-Middle (MITM) protection.
	  Implementation uses the "printk" function to display the passkey.

config BT_DIRECTED_ADVERTISING
	bool "Enable directed advertising"
	default y
	depends on BT_HIDS_SECURITY_ENABLED

endmenu
