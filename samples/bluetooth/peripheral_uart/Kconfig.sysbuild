config PARTITION_MANAGER
	default n

config MERGED_HEX_FILES
	default y if !SOC_SERIES_NRF54H

config NRF_DEFAULT_IPC_RADIO
	default y

config NETCORE_IPC_RADIO_BT_HCI_IPC
	default y

source "share/sysbuild/Kconfig"
