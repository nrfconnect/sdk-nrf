#ifndef IMAGE_DIGESTS_H_
#define IMAGE_DIGESTS_H_

#include <stdint.h>
#include <stdbool.h>

#define MFG_DIGEST_LEN 32U

static const uint8_t mfg_bl1_expected_digest[MFG_DIGEST_LEN]           = { @BL1_BYTES@ };
static const uint8_t mfg_bl2_slot_a_expected_digest[MFG_DIGEST_LEN]    = { @BL2A_BYTES@ };
static const uint8_t mfg_bl2_slot_b_expected_digest[MFG_DIGEST_LEN]    = { @BL2B_BYTES@ };
static const uint8_t mfg_app_candidate_expected_digest[MFG_DIGEST_LEN] = { @APPC_BYTES@ };

/* Returns true when a digest array consists entirely of zeros, which indicates
 * it was not provided at build time and validation should be skipped.
 */
static inline bool mfg_digest_is_zero(const uint8_t *digest)
{
	for (int i = 0; i < MFG_DIGEST_LEN; i++) {
		if (digest[i] != 0U) {
			return false;
		}
	}
	return true;
}

