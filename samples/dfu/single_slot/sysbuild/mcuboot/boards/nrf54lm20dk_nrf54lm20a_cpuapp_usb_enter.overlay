 / {
	chosen {
		zephyr,code-partition = &boot_partition;
		zephyr,boot-mode = &boot_mode0;
	};
};

/ {
	aliases {
		mcuboot-button0 = &button0;
	};
};       

&gpregret1 {
	status = "okay";

	boot_mode0: boot_mode@0 {
		compatible = "zephyr,retention";
		status = "okay";
		reg = <0x0 0x1>;
	};
};