source "Kconfig.zephyr"

menu "PSA TLS sample"

choice SAMPLE_PSA_TLS_CERTIFICATE_TYPE
	prompt "Certificate type"
	default SAMPLE_PSA_TLS_CERTIFICATE_TYPE_ECDSA
	help
	  Select the certificate type to use in the PSA TLS sample.

config SAMPLE_PSA_TLS_CERTIFICATE_TYPE_RSA
	bool "RSA certificate for the PSA TLS sample"
	help
	  Enable RSA certificates when testing ciphers that supports RSA for authentication.

config SAMPLE_PSA_TLS_CERTIFICATE_TYPE_ECDSA
	bool "ECDSA certificate for the PSA TLS sample"
	help
	  Enable ECDSA certificates when testing ciphers that supports ECDSA for authentication.

endchoice

choice SAMPLE_PSA_TLS_TYPE
	prompt "Server or client selection"
	default SAMPLE_PSA_TLS_TYPE_SERVER

config SAMPLE_PSA_TLS_TYPE_SERVER
	bool "Server functionality for the PSA TLS sample"
	help
	  When acting as a server, the sample waits for a connection from the client on port 4243.
	  After the TCP connection is established, the sample waits for the "ClientHello" message
	  from the client.

config SAMPLE_PSA_TLS_TYPE_CLIENT
	bool "Client functionality for the PSA TLS sample"
	help
	  When acting as a client, the sample tries to connect to the server on port 4243.
	  After the TCP connection is established, the sample automatically initiates the TLS handshake
	  by sending the "ClientHello" message.

endchoice

endmenu
