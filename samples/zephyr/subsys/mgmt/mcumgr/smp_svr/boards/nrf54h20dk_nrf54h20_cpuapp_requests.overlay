#include "../sysbuild/nrf54h20dk_nrf54h20_memory_map_requests.dtsi"

/ {
	chosen {
		zephyr,boot-mode = &boot_request;
		zephyr,code-partition = &cpuapp_slot0_partition;
	};
};

secondary_app_partition: &cpuapp_slot1_partition {};
