config USE_UI_MODULE
	bool "Enable UI module"
	default y
	help
	  Enable the User Interface module for user interaction on
	  development kit hardware.

menu "User Interface"
	visible if USE_UI_MODULE

endmenu

module = UI
module-str = User Interface
