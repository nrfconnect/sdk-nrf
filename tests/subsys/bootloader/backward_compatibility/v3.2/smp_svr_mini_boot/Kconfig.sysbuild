config MCUBOOT_SIGNATURE_USING_KMU
	default y if SOC_SERIES_NRF54L && !SOC_NRF54LS05B

config MCUBOOT_GENERATE_DEFAULT_KEY_FILE
	default y if SOC_SERIES_NRF54L && !SOC_NRF54LS05B

choice BOOT_SIGNATURE_TYPE
	default BOOT_SIGNATURE_TYPE_ECDSA_P256 if SOC_NRF54LS05B
	default BOOT_SIGNATURE_TYPE_ED25519 if !SOC_NRF54LS05B
endchoice

config BOOT_SIGNATURE_TYPE_PURE
	default y if !SOC_NRF54LS05B

choice MCUBOOT_MODE
	default MCUBOOT_MODE_DIRECT_XIP if SOC_NRF54LS05B
endchoice

config NRF_DEFAULT_IPC_RADIO
	default y if SOC_SERIES_NRF54H

config NETCORE_IPC_RADIO_BT_HCI_IPC
	default y if SOC_SERIES_NRF54H

config MCUBOOT_IMAGES_ROM_END_OFFSET_AUTO
	default "ipc_radio;ipc_radio_secondary_app" if MCUBOOT_SIGN_MERGED_BINARY

# NOTE: Backward compatibility with NCS v3.2.
# The original sample disables the Partition Manager, which makes the
# Direct-XIP variant image be generated by the upstream Zephyr mechanism and
# named "smp_svr_mini_boot_slot1_variant". NCS v3.2 builds the variant through
# the NCS Partition Manager flow, which keeps the legacy image name
# "mcuboot_secondary_app". Leaving the Partition Manager enabled here restores
# that legacy naming so the update image is consumed by the system test as in
# NCS v3.2.

source "share/sysbuild/Kconfig"
