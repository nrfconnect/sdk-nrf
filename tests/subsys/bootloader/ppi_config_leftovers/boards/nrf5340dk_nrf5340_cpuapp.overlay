	status = "okay";
};

&kmu {
	status = "okay";
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm_dummy>;
	pinctrl-1 = <&pwm_dummy>;
	pinctrl-names = "default", "sleep";
};

&pwm1 {
	status = "okay";
	pinctrl-0 = <&pwm_dummy>;
	pinctrl-1 = <&pwm_dummy>;
	pinctrl-names = "default", "sleep";
};

&pwm2 {
	status = "okay";
	pinctrl-0 = <&pwm_dummy>;
	pinctrl-1 = <&pwm_dummy>;
	pinctrl-names = "default", "sleep";
};

&pwm3 {
	status = "okay";
	pinctrl-0 = <&pwm_dummy>;
	pinctrl-1 = <&pwm_dummy>;
	pinctrl-names = "default", "sleep";
};

&qdec0 {
	status = "okay";
	pinctrl-0 = <&qdec_dummy>;
	pinctrl-1 = <&qdec_dummy>;
	pinctrl-names = "default", "sleep";
	steps = <127>;
	led-pre = <500>;
};

&qdec1 {
	status = "okay";
	pinctrl-0 = <&qdec_dummy>;
	pinctrl-1 = <&qdec_dummy>;
	pinctrl-names = "default", "sleep";
	steps = <127>;
	led-pre = <500>;
};

&rtc0 {
	status = "okay";
};

/* uart0 is used for console. */

&spi1 {
	status = "okay";
	pinctrl-0 = <&spi_dummy>;
	pinctrl-1 = <&spi_dummy>;
	pinctrl-names = "default", "sleep";
};

&spi2 {
	status = "okay";
	pinctrl-0 = <&spi_dummy>;
	pinctrl-1 = <&spi_dummy>;
	pinctrl-names = "default", "sleep";
};

&spi3 {
	status = "okay";
	pinctrl-0 = <&spi_dummy>;
	pinctrl-1 = <&spi_dummy>;
	pinctrl-names = "default", "sleep";
};


&spi4 {
	status = "okay";
	pinctrl-0 = <&spi_dummy>;
	pinctrl-1 = <&spi_dummy>;
	pinctrl-names = "default", "sleep";
};

&timer0 {
	status = "okay";
};

&timer1 {
	status = "okay";
