&timer2 {
	status = "okay";
};

&usbd {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&wdt1 {
	status = "okay";
};

&pinctrl {
	spi_dummy: spi_dummy {
		group1 {
			psels = <NRF_PSEL(SPIM_SCK, 0, 0)>,
				<NRF_PSEL(SPIM_MISO, 0, 0)>,
				<NRF_PSEL(SPIM_MOSI, 0, 0)>;
		};
	};

	pwm_dummy: pwm_dummy {
	group1 {
			psels = <NRF_PSEL(PWM_OUT0, 0, 0)>,
				<NRF_PSEL(PWM_OUT1, 0, 0)>,
				<NRF_PSEL(PWM_OUT2, 0, 0)>;
		};
	};

    qdec_dummy: qdec_dummy {
		group1 {
			psels = <NRF_PSEL(QDEC_A, 0, 0)>,   /* Arduino D0 */
				<NRF_PSEL(QDEC_B, 0, 0)>;   /* Arduino D2 */
		};
	};
};
