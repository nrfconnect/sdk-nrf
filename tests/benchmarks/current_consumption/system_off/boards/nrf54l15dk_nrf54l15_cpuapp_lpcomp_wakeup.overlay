	/*
	 * Redefine lpcomp to use RXD1
	 * Thus, when sending character from host, there will be lpcomp interrupt,
	 * waking up device from sleep.
	 */

&pinctrl {
	/*
	* Redefine: RXD1 -> P1.11 (AIN4)
	*/
	/omit-if-no-ref/ uart20_default: uart20_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 1, 4)>,
				<NRF_PSEL(UART_RTS, 1, 6)>;
		};
		group2 {
			psels = <NRF_PSEL(UART_RX, 1, 11)>,
				<NRF_PSEL(UART_CTS, 1, 7)>;
			bias-pull-up;
		};
	};

	/omit-if-no-ref/ uart20_sleep: uart20_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 1, 4)>,
				<NRF_PSEL(UART_RX, 1, 11)>,
				<NRF_PSEL(UART_RTS, 1, 6)>,
				<NRF_PSEL(UART_CTS, 1, 7)>;
			low-power-enable;
		};
	};
};

&comp {
	compatible = "nordic,nrf-lpcomp";
	psel = "AIN4";
	refsel = "VDD_7_8";
	status = "okay";
	enable-hyst;
};
