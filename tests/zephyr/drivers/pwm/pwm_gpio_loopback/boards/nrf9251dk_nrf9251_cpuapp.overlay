 *
 * Test requires wire connection between:
 *  - PWM130 OUT[0] at P1.00 <-> GPIO input at P1.01
 *  - PWM130 OUT[1] at P1.04 <-> GPIO input at P1.11
 *  - PWM130 OUT[2] at P2.01 <-> GPIO input at P2.02
 *  - PWM130 OUT[3] at P2.03 <-> GPIO input at P2.09
 */

/ {
	zephyr,user {
		pwms = <&pwm130 0 160000 PWM_POLARITY_NORMAL>,
		       <&pwm130 1 160000 PWM_POLARITY_NORMAL>,
		       <&pwm130 2 160000 PWM_POLARITY_NORMAL>,
		       <&pwm130 3 160000 PWM_POLARITY_NORMAL>;
		gpios = <&gpio1 1 GPIO_ACTIVE_HIGH>,
			<&gpio1 11 GPIO_ACTIVE_HIGH>,
			<&gpio2 2 GPIO_ACTIVE_HIGH>,
			<&gpio2 9 GPIO_ACTIVE_HIGH>;
	};
};

&pinctrl {
	pwm130_default: pwm130_default {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 0)>,
				<NRF_PSEL(PWM_OUT1, 1, 4)>,
				<NRF_PSEL(PWM_OUT2, 2, 1)>,
				<NRF_PSEL(PWM_OUT3, 2, 3)>;
		};
	};

	pwm130_sleep: pwm130_sleep {
		group1 {
			psels = <NRF_PSEL(PWM_OUT0, 1, 0)>,
				<NRF_PSEL(PWM_OUT1, 1, 4)>,
				<NRF_PSEL(PWM_OUT2, 2, 1)>,
				<NRF_PSEL(PWM_OUT3, 2, 3)>;
			low-power-enable;
		};
	};
};

&gpio1 {
	status = "okay";
};

&gpio2 {
	status = "okay";
};
