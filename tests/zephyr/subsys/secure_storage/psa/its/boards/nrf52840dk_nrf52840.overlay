/*
 * Hardware Unique Key partition for nRF52840.
 * Required when using HW_UNIQUE_KEY without Partition Manager.
 */
&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* Place at end of 1MB flash, size = FPROTECT_BLOCK_SIZE */
		hw_unique_key_partition: partition@ff000 {
			reg = <0xff000 0x1000>;
		};
	};
};
