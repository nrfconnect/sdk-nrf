/* Test requires GPIO loopback between P0.04 and P1.16. */

/ {
	resources {
		compatible = "test-hpf-gpio";
		out-gpios = <&hpf_gpio 16 0>;
		in-gpios = <&gpio0 4 0>;
	};
};

&gpiote30 {
	status = "okay";
};

&gpio0 {
	status = "okay";
};
