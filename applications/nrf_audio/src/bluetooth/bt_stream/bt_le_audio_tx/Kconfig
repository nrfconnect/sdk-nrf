menu "BT LE Audio TX"

config NRF_AUDIO_TX_LEAD_TIME_TGT_US
	int
	default 2500
	range NRF_AUDIO_TX_LEAD_TIME_MIN_US 10000
	help
	  Do not change this value unless you know what you are doing.
	  Target lead time to send data to controller before it sends the next SDU on air.

config NRF_AUDIO_TX_LEAD_TIME_MIN_US
	int
	default 2000
	help
	  Do not change this value unless you know what you are doing.
	  Min allowed lead time to send data to controller before it sends the next SDU on air.
	  Used to make sure that the data is sent to the controller just in time for the next SDU,
	  which can help with reducing the overall latency and power consumption.
	  Setting this too low may lead to flushed data.
	  Must be higher than HCI_ISO_TX_SDU_ARRIVAL_MARGIN_US plus a margin depending on SoC.
	  This value may take into account audio processing jitter,
	  which is caused by e.g. variable LC3 encoding time.
	  Modules may use this value in different ways.

config NRF_AUDIO_TX_LEAD_TIME_BASE_US
	int
	default 4700
	help
	  NOTE: The actual value is the one above + an SDU interval.
	  Do not change this value unless you know what you are doing.
	  Max allowed lead time to send data to the controller before it sends the next SDU on air.
	  This means data is sent too early/fast, and will flush one SDU.
	  This value may take into account audio processing jitter,
	  which is caused by e.g. variable LC3 encoding time.
	  Modules may use this value in different ways.

endmenu # BT LE Audio TX
