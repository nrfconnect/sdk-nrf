if WIFI_NM_WPA_SUPPLICANT && SOC_FAMILY_NORDIC_NRF

choice WIFI_NM_WPA_SUPPLICANT_CRYPTO_BACKEND
	default WIFI_NM_WPA_SUPPLICANT_CRYPTO_EXT
endchoice

config HOSTAP_CRYPTO_ALT_PSA
	bool "PSA crypto support for Wi-Fi using nRF Security"
	default y
	select PSA_CRYPTO
	# HostAP mbedtls alt still uses legacy MPI/cipher symbols from TF-PSA-Crypto.
	select MBEDTLS_DECLARE_PRIVATE_IDENTIFIERS
	select MBEDTLS_BIGNUM_C
	select MBEDTLS_PK_C
	select MBEDTLS_PK_PARSE_C
	select MBEDTLS_PK_WRITE_C
	select MBEDTLS_MD_C
	select MBEDTLS_ENABLE_HEAP
	select PSA_WANT_GENERATE_RANDOM
	select PSA_WANT_ALG_HMAC
	select PSA_WANT_KEY_TYPE_HMAC
	select PSA_WANT_ALG_CMAC
	select PSA_WANT_ALG_ECB_NO_PADDING
	select PSA_WANT_ALG_SHA_1
	select PSA_WANT_ALG_SHA_256
	# Zephyr hostap always defines CONFIG_SHA384; wpa_gmk_to_gtk() uses
	# sha384_prf() -> PSA_ALG_HMAC(PSA_ALG_SHA_384) for GMK/GTK derivation
	# and WPS/P2P GO needs it too.
	select PSA_WANT_ALG_SHA_384
	# Zephyr hostap always defines CONFIG_SHA512; sha512_prf() needs
	# PSA_ALG_HMAC(PSA_ALG_SHA_512) for SAE/FT and similar paths.
	select PSA_WANT_ALG_SHA_512
	select PSA_WANT_ALG_PBKDF2_HMAC
	select PSA_WANT_KEY_TYPE_PASSWORD
	select PSA_WANT_KEY_TYPE_AES
	# Personal/WPS/P2P pull in the fuller PSA cipher/hash set. Enterprise
	# keeps the lean set (it builds the mbedtls TLS stack on top) to stay
	# within RAM/flash budgets, matching the old legacy backend.
	select PSA_WANT_ALG_CBC_PKCS7 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_ACCEL_CBC_MAC_AES_128 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_ACCEL_CBC_MAC_AES_192 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_ACCEL_CBC_MAC_AES_256 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_CCM if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_GCM if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_CTR if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_MD5 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_ACCEL_MD5 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_SHA_224 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_PBKDF2_AES_CMAC_PRF_128 if !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_KEY_TYPE_ECC_PUBLIC_KEY if !HOSTAP_CRYPTO_ENTERPRISE
	help
	  Crypto backend for the WPA supplicant built on PSA Crypto with the
	  HostAP mbedtls alt glue. This is the single backend for all Wi-Fi
	  modes: WPA2/WPA3 personal, and with the enterprise and WPS/P2P
	  options it also covers EAP and WPS/P2P.

# Internal bignum WPA3 is incompatible with the PSA alt backend; defaults use
# EXT when HOSTAP_CRYPTO_WPA3_PSA is enabled (see Kconfig.defconfig).
config WIFI_NM_WPA_SUPPLICANT_WPA3_IMPLEMENTATION_INT
	depends on !HOSTAP_CRYPTO_ALT_PSA

if WIFI_NM_WPA_SUPPLICANT_CRYPTO_ENTERPRISE

config HOSTAP_CRYPTO_ENTERPRISE
	bool "Enterprise Crypto support for Wi-Fi using nRF Security"
	depends on HOSTAP_CRYPTO_ALT_PSA
	default y
	select MBEDTLS
	select PSA_WANT_ALG_HMAC
	select PSA_WANT_ALG_TLS12_PRF
	select PSA_WANT_ALG_TLS12_PSK_TO_MS
	select PSA_WANT_ALG_ECDH
	select PSA_WANT_ECC_SECP_R1_256
	# Enterprise EAP-TLS pulls in the mbedtls software TLS/X.509 stack on
	# top of the PSA backend, which needs its own entropy/DRBG and ciphers.
	select MBEDTLS_ECP_C
	select MBEDTLS_ECDSA_C
	select MBEDTLS_MD_C
	select MBEDTLS_AES_C
	select MBEDTLS_SHA256_C
	select MBEDTLS_ENTROPY_C
	select MBEDTLS_CTR_DRBG_C
	select MBEDTLS_HMAC_DRBG_C
	select MBEDTLS_PKCS5_C
	select MBEDTLS_SSL_TLS_C
	select MBEDTLS_SSL_SRV_C
	select MBEDTLS_SSL_CLI_C
	select MBEDTLS_X509_LIBRARY
	select MBEDTLS_TLS_LIBRARY
	select MBEDTLS_X509_CRL_PARSE_C
	select MBEDTLS_TLS_VERSION_1_2
	select MBEDTLS_RSA_C
	select MBEDTLS_SSL_SERVER_NAME_INDICATION
	# Default test_certs/rsa3k (CMake) use RSA-3072 and sha384WithRSAEncryption.
	select PSA_WANT_RSA_KEY_SIZE_3072
	select PSA_WANT_ALG_SHA_384

endif

# WPA3 over PSA is personal security only for now
if HOSTAP_CRYPTO_ALT_PSA

config HOSTAP_CRYPTO_WPA3_PSA
	bool "WPA3 PSA support"
	depends on !SOC_SERIES_NRF54H && !WIFI_NM_WPA_SUPPLICANT_AP
	# Off by default for enterprise: WPA3 SAE is personal-only and the PSA
	# PAKE driver does not fit the already tight enterprise EAP-TLS budget.
	# It can still be enabled explicitly on boards with spare RAM/flash.
	default y if !SOC_SERIES_NRF54H && !HOSTAP_CRYPTO_ENTERPRISE
	select PSA_WANT_ALG_WPA3_SAE_FIXED
	select PSA_WANT_ALG_WPA3_SAE_H2E
	select PSA_WANT_KEY_TYPE_WPA3_SAE
	select PSA_WANT_ECC_SECP_R1_256

endif

endif
