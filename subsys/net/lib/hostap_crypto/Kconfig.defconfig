# PSA backend defaults: WPA3 via external PSA implementation.
if WIFI_NM_WPA_SUPPLICANT && SOC_FAMILY_NORDIC_NRF && HOSTAP_CRYPTO_ALT_PSA

choice WIFI_NM_WPA_SUPPLICANT_WPA3_IMPLEMENTATION
	default WIFI_NM_WPA_SUPPLICANT_WPA3_IMPLEMENTATION_EXT if HOSTAP_CRYPTO_WPA3_PSA
	default WIFI_NM_WPA_SUPPLICANT_WPA3_IMPLEMENTATION_NONE if !HOSTAP_CRYPTO_WPA3_PSA
endchoice

endif # WIFI_NM_WPA_SUPPLICANT && SOC_FAMILY_NORDIC_NRF && HOSTAP_CRYPTO_ALT_PSA

# RSA-3072 EAP-TLS needs MPI >= 384 bytes (see nrf_security Kconfig.legacy).
if HOSTAP_CRYPTO_ENTERPRISE

config MBEDTLS_MPI_MAX_SIZE
	default 384

endif # HOSTAP_CRYPTO_ENTERPRISE
