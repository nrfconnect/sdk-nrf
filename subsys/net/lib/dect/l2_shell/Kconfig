config DECT_L2_SHELL_LIB
	bool "DECT L2 shell library"
	depends on NET_MGMT
	depends on NET_MGMT_EVENT
	depends on NET_MGMT_EVENT_INFO
	depends on NET_L2_DECT_MGMT
	depends on GETOPT_LIB
	depends on DECT_UTILS_LIB
	help
	  DECT L2 shell library providing shell commands for DECT NR+ network
	  management interface.
	  Note: This library requires GETOPT_LIB (freebsd-getopt) which conflicts
	  with Zephyr's POSIX_C_LIB_EXT getopt implementation.
	  When using this library, POSIX_C_LIB_EXT must be disabled in prj.conf.
