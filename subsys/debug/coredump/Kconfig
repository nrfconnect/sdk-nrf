if DEBUG_COREDUMP_BACKEND_OTHER

choice DEBUG_COREDUMP_BACKEND_NRF
	prompt "nRF core dump storage implementation"
	default DEBUG_COREDUMP_BACKEND_NRF_FLASH_PARTITION
	help
	  Select whether core dumps are written to on-chip non-volatile memory or to a
	  dedicated SRAM region (survives soft reset, not power loss).

config DEBUG_COREDUMP_BACKEND_NRF_FLASH_PARTITION
	bool "Internal flash or RRAM (partition coredump_partition) [EXPERIMENTAL]"
	depends on DT_HAS_NORDIC_NRF51_FLASH_CONTROLLER_ENABLED || \
		   DT_HAS_NORDIC_NRF52_FLASH_CONTROLLER_ENABLED || \
		   DT_HAS_NORDIC_NRF53_FLASH_CONTROLLER_ENABLED || \
		   DT_HAS_NORDIC_NRF91_FLASH_CONTROLLER_ENABLED || \
		   DT_HAS_NORDIC_RRAM_CONTROLLER_ENABLED
	depends on !BUILD_WITH_TFM
	select FLASH_MAP
	select EXPERIMENTAL
	help
	  Enables the Zephyr core dump backend that saves a core dump to the
	  flash or RRAM partition named "coredump_partition". This backend is
	  similar to the one enabled with DEBUG_COREDUMP_BACKEND_FLASH_PARTITION
	  option except that it bypasses the Zephyr flash device layer and uses
	  nrfx library directly.

config DEBUG_COREDUMP_BACKEND_NRF_RAM_REGION
	bool "Dedicated SRAM region (devicetree coredump_storage_region) [EXPERIMENTAL]"
	depends on $(dt_nodelabel_enabled,coredump_storage_region)
	select EXPERIMENTAL
	help
	  Stores raw core dump bytes in a reserved SRAM block defined in devicetree
	  (nodelabel coredump_storage_region), with the same header and CRC layout as
	  the flash/RRAM backend. Suitable when non-volatile coredump storage is
	  undesirable or unavailable.

endchoice

config DEBUG_COREDUMP_BACKEND_NRF_WRITE_BUF_SIZE
	int "Coredump backend streaming buffer size"
	depends on DEBUG_COREDUMP_BACKEND_NRF_FLASH_PARTITION || \
		   DEBUG_COREDUMP_BACKEND_NRF_RAM_REGION
	default 128

endif # DEBUG_COREDUMP_BACKEND_OTHER
