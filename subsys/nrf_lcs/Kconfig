menuconfig NRF_LCS
	bool "Life Cycle State handling"
	select EXPERIMENTAL
	help
	  Enable device Life Cycle State subsystem.

if NRF_LCS

choice NRF_LCS_MEM
	prompt "LCS memory storage backend"
	default NRF_LCS_MEM_BL_STORAGE

config NRF_LCS_MEM_BL_STORAGE
	bool "Bootloader Storage"
	depends on SECURE_BOOT_STORAGE
	help
	  Store Life Cycle State values in bootloader storage.

endchoice # NRF_LCS_MEM

module = NRF_LCS
module-str = Life Cycle State
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

endif # NRF_LCS
