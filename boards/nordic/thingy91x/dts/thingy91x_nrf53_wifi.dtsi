&i2c2 {
	status = "okay";
};

&spi3 {
	status = "okay";
};

/ {
	chosen {
		nordic,pm-ext-flash = &flash_ext;
		zephyr,wifi = &nordic_wlan0;
	};
};

/* enable short range rf */
&ldsw_rf_fe_sr_en {
	/delete-property/ output-low;
	output-high;
};

/* set pmic_wifi enable signal  */
&ldsw_nPM60_en {
	regulator-boot-on;
};

/* enable pmic_wifi */
&pmic_wifi {
	status = "okay";
	regulators {
		status = "okay";
	};
};

/* enable nrf70 */
&nrf700x {
	status = "okay";
};

&flash_ext {
	status = "okay";
};

&pmic_main {
	status = "okay";
	npm1300_gpios {
		status = "okay";
	};
	regulators {
		status = "okay";
	};
	charger {
		status = "okay";
	};
};
