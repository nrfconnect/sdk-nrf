config BOARD_NRF9251PDK
	select SOC_NRF9251_CPUAPP if (BOARD_NRF9251PDK_NRF9251_CPUAPP)
	select SOC_NRF9251_CPUPPR if (BOARD_NRF9251PDK_NRF9251_CPUPPR)
	select SOC_NRF9251_CPUFLPR if (BOARD_NRF9251PDK_NRF9251_CPUFLPR)

